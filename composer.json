{
    "name": "alphaxio/nexakit",
    "description": "A unified developer toolkit for building emerging market applications in Laravel.",
    "license": "MIT",
    "authors": [
        {
            "name": "Isaac",
            "email": "alphaxio47@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0||^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0||^9.0||^10.0||^11.0",
        "phpunit/phpunit": "^10.0||^11.0"
    },
    "autoload": {
        "psr-4": {
            "Alphaxio\\Nexakit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Alphaxio\\Nexakit\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Alphaxio\\Nexakit\\NexakitServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
